# Database (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/dawgcity

# Google OAuth - get from console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Cookie signing - generate with: openssl rand -hex 32
# Must be at least 64 bytes
COOKIE_SECRET=your_64_byte_secret_here_generate_with_openssl_rand_hex_32_x2

# Anthropic API - get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# App
PORT=3000
RUST_LOG=dawg_city=debug,tower_http=debug
