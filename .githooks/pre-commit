#!/bin/bash
# Pre-commit hook to scan for secret patterns

echo "🔍 Scanning staged files for secrets..."

# Patterns to block
patterns=(
    "SUPABASE_KEY"
    "RECAPTCHA_SECRET"
    "STRIPE_SECRET"
    "AWS_SECRET"
    "api_key"
    "private_key"
    "BEGIN.*PRIVATE.*KEY"
)

EXIT_CODE=0

for pattern in "${patterns[@]}"; do
    if git diff --cached --name-only --diff-filter=ACM | xargs grep -l "$pattern" 2>/dev/null; then
        echo "❌ BLOCKED: Potential secret pattern detected: $pattern"
        echo "   Run: git diff --cached | grep -i '$pattern' to see details"
        EXIT_CODE=1
    fi
done

if [ $EXIT_CODE -eq 0 ]; then
    echo "✅ No obvious secrets detected"
fi

exit $EXIT_CODE
